{
  "name": "contechnews",
  "version": "1.5.6",
  "private": true,
  "scripts": {
    "start": "cross-env SOCKET=true node ./scripts/next-remote-watch.js ./data",
    "dev": "next dev",
    "build": "next build && node ./scripts/generate-rss.js && node ./scripts/generate-sitemap && node ./scripts/indexnow.js",
    "serve": "next start",
    "analyze": "cross-env ANALYZE=true next build",
    "lint": "next lint --fix --dir pages --dir components --dir lib --dir layouts --dir scripts",
    "prepare": "husky install",
    "commit": "git add . && git commit -m 'production push' && git push",
    "deploy": "pnpm i && next build && pnpm vercel && pnpm vercel --prod && pnpm run commit",
    "restart": "rm .next && pnpm rm node_modules && rm pnpm-lock.yaml && pnpm i && pnpm run build"
  },
  "dependencies": {
    "@fontsource/inter": "4.5.2",
    "@mailchimp/mailchimp_marketing": "^3.0.80",
    "@next/bundle-analyzer": "^14.2.35",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.4.1",
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.5.0",
    "axios": "^1.16.1",
    "canvas": "^3.2.3",
    "dotenv": "^16.6.1",
    "esbuild": "^0.13.15",
    "framer-motion": "^4.1.17",
    "github-slugger": "^1.5.0",
    "gray-matter": "^4.0.3",
    "image-size": "1.0.0",
    "js-yaml": "^4.1.1",
    "katex": "^0.16.47",
    "link": "^1.6.0",
    "mdast-util-to-string": "^4.0.0",
    "mdx-bundler": "^8.1.0",
    "mermaid": "^11.15.0",
    "next": "^14.2.35",
    "next-mdx-enhanced": "^5.0.0",
    "next-pwa": "^5.6.0",
    "next-seo": "^6.8.0",
    "next-themes": "^0.0.14",
    "node-polyfill-webpack-plugin": "^3.0.0",
    "nodejs-polyfill": "^1.4.1",
    "postcss": "^8.5.15",
    "preact": "^10.29.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "reading-time": "1.3.0",
    "rehype-autolink-headings": "^6.1.1",
    "rehype-citation": "^0.4.0",
    "rehype-katex": "^6.0.3",
    "rehype-preset-minify": "6.0.0",
    "rehype-prism-plus": "^1.6.3",
    "rehype-slug": "^5.1.0",
    "remark-footnotes": "^4.0.1",
    "remark-gfm": "^3.0.1",
    "remark-math": "^5.1.1",
    "tailwind-scrollbar-hide": "^1.3.1",
    "tailwindcss": "^3.4.19",
    "unist-util-visit": "^4.1.2",
    "vercel": "^32.7.2",
    "webpack": "^5.107.0",
    "xml": "^1.0.1"
  },
  "devDependencies": {
    "@svgr/webpack": "^6.5.1",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.4",
    "dedent": "^0.7.0",
    "eslint": "^7.32.0",
    "eslint-config-next": "14.2.35",
    "eslint-config-prettier": "^8.10.2",
    "eslint-plugin-prettier": "^3.4.1",
    "fast-glob": "^3.3.3",
    "file-loader": "^6.2.0",
    "globby": "11.0.3",
    "husky": "^6.0.0",
    "inquirer": "^8.2.7",
    "lint-staged": "^11.2.6",
    "next-remote-watch": "^1.0.0",
    "postcss-import": "^16.1.1",
    "postcss-loader": "^8.2.1",
    "prettier": "^2.8.8",
    "prettier-plugin-tailwindcss": "^0.1.13",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "style-loader": "^4.0.0"
  },
  "lint-staged": {
    "*.+(js|jsx|ts|tsx)": [
      "eslint --fix"
    ],
    "*.+(js|jsx|ts|tsx|json|css|md|mdx)": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.33.4"
}
